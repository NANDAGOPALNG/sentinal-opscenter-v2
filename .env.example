APP_NAME="Sentinal OpsCenter V2"
LOG_LEVEL=info

# Required for PlannerAgent and FixerAgent.
GROQ_API_KEY=your_groq_api_key_here

# Optional. Defaults to llama-3.3-70b-versatile in shared/config/settings.py.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional GitHub read-only enrichment.
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=NANDAGOPALNG/sentinal-opscenter-v2

# Optional GitHub webhook security. If set, /webhook requires X-Hub-Signature-256.
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional future integrations.
TAVILY_API_KEY=your_tavily_api_key_here
DISCORD_WEBHOOK_URL=
OMIUM_API_KEY=
OMIUM_PROJECT=sentinal-opscenter-v2
